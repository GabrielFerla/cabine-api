# Template de variaveis de ambiente.
# Copie para .env antes de subir a API ou rodar os testes:
#   Windows:    copy .env.example .env
#   Linux/Mac:  cp .env.example .env
#
# (o .env real NAO e versionado — esta no .gitignore)

# Conexao com o MySQL (bate com o docker-compose.yml deste repo).
DATABASE_URL=mysql+pymysql://cabine:cabine123@localhost:3306/cabine

# Chave de assinatura do JWT. TROQUE por uma chave forte antes da entrega:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_KEY=troque-por-uma-chave-aleatoria-de-32-caracteres-ou-mais

# Validade do token de acesso (em minutos).
JWT_EXPIRE_MINUTES=60
